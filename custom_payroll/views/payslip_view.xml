<odoo>
    <record id="view_hr_payslip_form_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="om_hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='credit_note']" position="after">
           
                    <field name="x_salary_pay_date"/>
                    <field name="x_total_working_days"/>
                    <field name="x_paid_days"/>
                    <field name="x_paid_leave"/>
                    <field name="x_unpaid_leave"/>
                    <field name="x_leave_balance"/>


            </xpath>

        </field>
    </record>
</odoo>